LLM_PROVIDER=custom
LLM_API_KEY=your_api_key_here
LLM_API_BASE_URL=https://your-provider-base-url/v1
LLM_MODEL=your-model-name
LLM_ENDPOINT_TYPE=chat_completions
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=120
LLM_REQUEST_TIMEOUT_MS=15000
LLM_ENABLE_AI_PATIENT=true
PATIENT_AGENT_ALLOWED_ORIGIN=https://niubi1v.github.io

# GitHub Pages 前端构建时可配置；也可以在页面设置中手动填写后端 API 地址。
NEXT_PUBLIC_PATIENT_AGENT_API_URL=https://your-backend-domain/api/patient-reply
