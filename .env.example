# Case set
# v2_only: only P001-P012
# v2_plus_30: P001-P012 + HX-ADD-001-HX-ADD-030
CASE_SET=v2_plus_30
NEXT_PUBLIC_CASE_SET=v2_plus_30

# Generic LLM provider for the Vercel AI Agent API.
# Do not put real keys in GitHub.
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key_here
LLM_API_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_ENDPOINT_TYPE=chat_completions
# chat_completions默认启用SSE，以采集真实首Token耗时；仅兼容不支持SSE的供应商时设为false。
LLM_STREAMING_ENABLED=true
# 标准化患者只需要简短最终回答；关闭V4默认思考模式，避免最终content为空。
LLM_THINKING_MODE=disabled
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500
LLM_REQUEST_TIMEOUT_MS=15000
LLM_ENABLE_AI_AGENTS=true
LLM_ENABLE_AI_PATIENT=true
# Cross-request provider circuit breaker. Server-only; shares the durable Upstash store below.
LLM_PROVIDER_CIRCUIT_STORE_MODE=upstash
LLM_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
LLM_PROVIDER_CIRCUIT_OPEN_SECONDS=30
LLM_PROVIDER_CIRCUIT_PROBE_SECONDS=15
LLM_PROVIDER_CIRCUIT_FAILURE_TTL_SECONDS=600
LLM_PROVIDER_CIRCUIT_STORE_TIMEOUT_MS=1000

# Optional short-lived in-memory caches. Defaults are safe for serverless practice use.
PATIENT_SESSION_TTL_MS=1800000
PATIENT_ANSWER_CACHE_TTL_MS=900000
PATIENT_SESSION_CACHE_MAX=200
PATIENT_ANSWER_CACHE_MAX=500

# DeepSeek example:
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_deepseek_api_key
# LLM_API_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# LLM_ENDPOINT_TYPE=chat_completions
# LLM_STREAMING_ENABLED=true
# LLM_THINKING_MODE=disabled

# CORS and abuse protection for the cost-sensitive Patient/session APIs.
AGENT_API_ALLOWED_ORIGINS=https://niubi1v.github.io
AGENT_CHAT_RATE_LIMIT_PER_MINUTE=30
SESSION_INIT_RATE_LIMIT_PER_MINUTE=60
AGENT_API_RATE_LIMIT_WINDOW_MS=60000
# Durable Patient Agent admission budgets. These are server-only and share the Upstash store below.
AGENT_REQUEST_STORE_MODE=upstash
AGENT_SESSION_REQUEST_LIMIT=60
AGENT_ATTEMPT_REQUEST_LIMIT=80
AGENT_ATTEMPT_INPUT_CHAR_LIMIT=120000
AGENT_IP_HOURLY_REQUEST_LIMIT=120
AGENT_IP_DAILY_REQUEST_LIMIT=500
AGENT_PROJECT_DAILY_REQUEST_LIMIT=5000
AGENT_PROJECT_DAILY_TOKEN_BUDGET=2000000
AGENT_SESSION_PROBE_LIMIT=3
AGENT_SESSION_LEASE_SECONDS=30
# Optional: when set, no-Origin server-to-server calls must send x-agent-api-token.
AGENT_API_SERVER_TOKEN=

# Single public API origin. Endpoint paths are generated by src/lib/apiConfig.ts.
NEXT_PUBLIC_API_BASE_URL=https://hematuria-training-system.vercel.app

# Public GitHub Pages builds are practice-only. Use "formal" only with authenticated
# teacher/assessment APIs and clinically approved cases.
NEXT_PUBLIC_DEPLOYMENT_TIER=practice
TRAINING_API_ALLOWED_ORIGINS=https://niubi1v.github.io
TRAINING_API_RATE_LIMIT_PER_MINUTE=90
# Dedicated server-only HMAC secret for signed attempt state. Generate a long random value.
TRAINING_STATE_SECRET=replace_with_at_least_32_random_bytes
# Vercel/Production attempts require a shared atomic store. Keep credentials server-only.
TRAINING_ATTEMPT_STORE_MODE=upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Keep "practice" until authenticated users, durable storage, and approved cases exist.
TRAINING_DEPLOYMENT_TIER=practice

# Optional server-side Azure Speech. Never prefix secrets with NEXT_PUBLIC_.
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastasia
TTS_ALLOWED_ORIGINS=https://niubi1v.github.io
TTS_RATE_LIMIT_PER_MINUTE=30
TTS_REQUEST_TIMEOUT_MS=10000
# Durable TTS admission. Server-only; reuses the Upstash credentials above and never stores audio.
TTS_REQUEST_STORE_MODE=upstash
TTS_SESSION_DAILY_REQUEST_LIMIT=60
TTS_IP_HOURLY_REQUEST_LIMIT=120
TTS_IP_DAILY_REQUEST_LIMIT=500
TTS_PROJECT_DAILY_REQUEST_LIMIT=5000
TTS_PROJECT_DAILY_CHAR_BUDGET=1000000
TTS_TUPLE_LEASE_SECONDS=30
