# Case set
# v2_only: only P001-P012
# v2_plus_30: P001-P012 + HX-ADD-001-HX-ADD-030
CASE_SET=v2_plus_30
NEXT_PUBLIC_CASE_SET=v2_plus_30

# Generic LLM provider for the Vercel AI Agent API.
# Do not put real keys in GitHub.
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key_here
LLM_API_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_ENDPOINT_TYPE=chat_completions
# 标准化患者只需要简短最终回答；关闭V4默认思考模式，避免最终content为空。
LLM_THINKING_MODE=disabled
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500
LLM_REQUEST_TIMEOUT_MS=15000
LLM_ENABLE_AI_AGENTS=true
LLM_ENABLE_AI_PATIENT=true

# DeepSeek example:
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your_deepseek_api_key
# LLM_API_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# LLM_ENDPOINT_TYPE=chat_completions
# LLM_THINKING_MODE=disabled

# CORS for the backend API.
AGENT_API_ALLOWED_ORIGIN=https://niubi1v.github.io
PATIENT_AGENT_ALLOWED_ORIGIN=https://niubi1v.github.io

# Frontend build-time Agent backend URL.
NEXT_PUBLIC_AGENT_API_URL=https://hematuria-training-system.vercel.app/api/agent-chat/
VITE_AGENT_API_URL=https://hematuria-training-system.vercel.app/api/agent-chat/
NEXT_PUBLIC_SESSION_INIT_API_URL=https://hematuria-training-system.vercel.app/api/session/init/
VITE_SESSION_INIT_API_URL=https://hematuria-training-system.vercel.app/api/session/init/
NEXT_PUBLIC_PATIENT_AGENT_API_URL=https://hematuria-training-system.vercel.app/api/patient-reply

# Public GitHub Pages builds are practice-only. Use "formal" only with authenticated
# teacher/assessment APIs and clinically approved cases.
NEXT_PUBLIC_DEPLOYMENT_TIER=practice
NEXT_PUBLIC_TRAINING_API_URL=https://hematuria-training-system.vercel.app/api/training-action
TRAINING_API_ALLOWED_ORIGINS=https://niubi1v.github.io
TRAINING_API_RATE_LIMIT_PER_MINUTE=90
# Dedicated server-only HMAC secret for signed attempt state. Generate a long random value.
TRAINING_STATE_SECRET=replace_with_at_least_32_random_bytes
# Keep "practice" until authenticated users, durable storage, and approved cases exist.
TRAINING_DEPLOYMENT_TIER=practice

# Optional server-side Azure Speech. Never prefix secrets with NEXT_PUBLIC_.
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastasia
TTS_ALLOWED_ORIGINS=https://niubi1v.github.io
TTS_RATE_LIMIT_PER_MINUTE=30
TTS_REQUEST_TIMEOUT_MS=10000
NEXT_PUBLIC_TTS_API_URL=https://hematuria-training-system.vercel.app/api/tts
