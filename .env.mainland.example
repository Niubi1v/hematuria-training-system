# Copy to .env.mainland on the CVM. Values below are placeholders only.
# Never commit the populated file and never add NEXT_PUBLIC_ to secrets.
NODE_ENV=<production>
APP_ORIGIN=<https://staging.example.cn>
TRUSTED_ORIGINS=<https://staging.example.cn>
MAINLAND_RUNTIME=<1>
TRAINING_DEPLOYMENT_TIER=<mainland-staging>
CASE_SET=<v2_plus_30>
NEXT_PUBLIC_CASE_SET=<v2_plus_30>
NEXT_PUBLIC_DEPLOYMENT_TIER=<mainland-staging>
MAINLAND_DOMAIN=<staging.example.cn>
MAINLAND_HTTP_PORT=<80>
MAINLAND_HTTPS_PORT=<443>
NGINX_TEMPLATE_PATH=<./nginx.conf.example>
TLS_CERT_DIR=</absolute/server/certificate-directory>
MAINLAND_IMAGE_TAG=<immutable-release-tag>

# Independent server-only secrets with different responsibilities.
TRAINING_STATE_SECRET=<GENERATE_UNIQUE_48_BYTE_SECRET>
AGENT_API_SERVER_TOKEN=<GENERATE_SEPARATE_SERVER_TOKEN>

# Explicit standard Redis selection. Never use an Upstash REST URL here.
TRAINING_ATTEMPT_STORE_MODE=<redis>
REDIS_URL=<redis-or-rediss-private-url>
REDIS_KEY_PREFIX=<mainland-staging:environment-id>
REDIS_CONNECT_TIMEOUT_MS=<5000>
REDIS_COMMAND_TIMEOUT_MS=<5000>
REDIS_TLS=<false-or-true>
REDIS_CA_FILE=<optional-private-ca-path>
TRAINING_ATTEMPT_TTL_SECONDS=<86400>
SESSION_TTL_SECONDS=<1800>

# DeepSeek is server-only. Blank/missing live settings fail closed.
LLM_PROVIDER=<deepseek>
LLM_API_KEY=<DEEPSEEK_SERVER_ONLY_API_KEY>
LLM_API_BASE_URL=<https://api.deepseek.com>
LLM_MODEL=<deepseek-chat>
LLM_ENDPOINT_TYPE=<chat_completions>
LLM_STREAMING_ENABLED=<true>
LLM_THINKING_MODE=<disabled>
LLM_TEMPERATURE=<0.2>
LLM_MAX_TOKENS=<500>
LLM_REQUEST_TIMEOUT_MS=<15000>
LLM_ENABLE_AI_AGENTS=<true>
LLM_ENABLE_AI_PATIENT=<true>
LLM_PROVIDER_CIRCUIT_STORE_MODE=<redis>
MAINLAND_SAFE_MOCK_LLM=<false>

# Same-origin allowlists. Keep all three equal to APP_ORIGIN.
AGENT_API_ALLOWED_ORIGINS=<https://staging.example.cn>
TRAINING_API_ALLOWED_ORIGINS=<https://staging.example.cn>
TTS_ALLOWED_ORIGINS=<https://staging.example.cn>

# Application and edge rate limits.
AGENT_CHAT_RATE_LIMIT_PER_MINUTE=<30>
SESSION_INIT_RATE_LIMIT_PER_MINUTE=<60>
AGENT_API_RATE_LIMIT_WINDOW_MS=<60000>
TRAINING_API_RATE_LIMIT_PER_MINUTE=<90>
TTS_RATE_LIMIT_PER_MINUTE=<30>
AGENT_REQUEST_STORE_MODE=<memory>
TTS_REQUEST_STORE_MODE=<memory>
MAINLAND_MAX_BODY_BYTES=<131072>
LOG_LEVEL=<info>

# Optional server-only speech provider.
AZURE_SPEECH_KEY=<optional-server-only-key>
AZURE_SPEECH_REGION=<eastasia>
