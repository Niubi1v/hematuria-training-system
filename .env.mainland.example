# Copy to .env.mainland on the server. Never commit the populated file.
CASE_SET=v2_plus_30
NEXT_PUBLIC_CASE_SET=v2_plus_30
NEXT_PUBLIC_DEPLOYMENT_TIER=practice
TRAINING_DEPLOYMENT_TIER=practice

# Same-origin browser contract. Do not set NEXT_PUBLIC_API_BASE_URL.
MAINLAND_RUNTIME=1
AGENT_API_ALLOWED_ORIGINS=https://review.example.cn
TRAINING_API_ALLOWED_ORIGINS=https://review.example.cn
TTS_ALLOWED_ORIGINS=https://review.example.cn

# Generate independently: openssl rand -base64 48
TRAINING_STATE_SECRET=replace_with_a_unique_random_value_at_least_32_bytes
AGENT_API_SERVER_TOKEN=replace_with_a_separate_random_server_token

# Explicit fail-closed adapter selection.
TRAINING_ATTEMPT_STORE_MODE=redis
REDIS_NAMESPACE=mainland-poc

# Local Compose:
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=replace_with_a_unique_local_redis_password
REDIS_TLS=false

# Managed Redis alternative (Tencent Cloud Redis or Aliyun Tair):
# REDIS_URL=rediss://username:password@private-endpoint.example:6379
# When REDIS_URL is set, remove REDIS_HOST/PORT/USERNAME/PASSWORD/TLS above.
# For a private CA, set REDIS_CA_DIR=/host/path/to/ca-directory for Compose and use:
# REDIS_CA_FILE=/app/redis-ca/redis-ca.pem
REDIS_CA_FILE=
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_COMMAND_TIMEOUT_MS=5000

# DeepSeek is called only by the server. Leave key empty for configuration checks;
# use an approved safe mock during non-AI POC verification. Never use NEXT_PUBLIC_.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_API_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_ENDPOINT_TYPE=chat_completions
LLM_STREAMING_ENABLED=true
LLM_THINKING_MODE=disabled
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500
LLM_REQUEST_TIMEOUT_MS=15000
LLM_ENABLE_AI_AGENTS=true
LLM_ENABLE_AI_PATIENT=true
# Local POC only: point LLM_API_BASE_URL at the internal mock service and set
# this true. Mock responses are labeled safe_mock and must never count as live AI.
MAINLAND_SAFE_MOCK_LLM=false

# In-memory rate limits are per app container; Nginx adds an outer per-IP limit.
AGENT_CHAT_RATE_LIMIT_PER_MINUTE=30
SESSION_INIT_RATE_LIMIT_PER_MINUTE=60
AGENT_API_RATE_LIMIT_WINDOW_MS=60000
TRAINING_API_RATE_LIMIT_PER_MINUTE=90
TTS_RATE_LIMIT_PER_MINUTE=30
MAINLAND_MAX_BODY_BYTES=131072

# The existing auxiliary admission stores remain Upstash-compatible. The provider
# circuit uses standard Redis; the first single-app POC keeps agent/TTS admission
# in memory behind Nginx limits. Reassess before horizontal scaling.
AGENT_REQUEST_STORE_MODE=memory
LLM_PROVIDER_CIRCUIT_STORE_MODE=redis
TTS_REQUEST_STORE_MODE=memory

# Optional server-only Azure Speech.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastasia
